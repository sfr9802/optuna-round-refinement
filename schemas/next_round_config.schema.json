{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/optuna-round-refinement/next_round_config.schema.json",
  "title": "NextRoundConfig",
  "description": "Declarative configuration for the next Optuna round. Produced by the LLM round-analyst (or a human) from a completed round's StudyBundle.",
  "type": "object",
  "required": [
    "schema_version",
    "round_id",
    "n_trials",
    "sampler",
    "pruner",
    "search_space",
    "provenance"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "round_id": {
      "type": "string",
      "pattern": "^round_[0-9]{2,}$",
      "description": "Target round this config produces."
    },
    "n_trials": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of trials to run in the target round."
    },
    "evaluate": {
      "type": "string",
      "pattern": "^[A-Za-z_][\\w.]*:[A-Za-z_]\\w*$",
      "description": "Dotted-path pointer 'module:callable' to the project's evaluate function. Operator-set; typically carried forward unchanged across rounds. Consumed by scripts/round_runner.py; the outer-loop analyst MUST preserve this field when proposing the next round."
    },
    "direction": {
      "type": "string",
      "enum": ["maximize", "minimize"],
      "description": "Optimization direction for the objective. Defaults to 'maximize' when omitted."
    },
    "objective_name": {
      "type": "string",
      "description": "Human-readable name of the objective metric (e.g. 'val_auc'). Surfaced in the bundle's 'objective.name' field."
    },
    "study_id": {
      "type": "string",
      "description": "Optional Optuna study name. Defaults to 'round_<round_id>' when absent."
    },
    "sampler": {
      "type": "object",
      "required": ["type", "params"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "examples": ["TPESampler", "CmaEsSampler", "RandomSampler", "GridSampler"] },
        "params": { "type": "object" },
        "seed": { "type": ["integer", "null"] }
      }
    },
    "pruner": {
      "type": "object",
      "required": ["type", "params"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "examples": ["MedianPruner", "HyperbandPruner", "NopPruner"] },
        "params": { "type": "object" }
      }
    },
    "search_space": {
      "type": "object",
      "description": "Frozen search space for this round.",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/param" }
    },
    "fixed_params": {
      "type": "object",
      "description": "Params held constant this round (e.g. previously-frozen axes).",
      "additionalProperties": { "type": ["number", "integer", "string", "boolean"] }
    },
    "stop_conditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_rounds":            { "type": ["integer", "null"], "minimum": 1 },
        "max_total_trials":      { "type": ["integer", "null"], "minimum": 1 },
        "target_value":          { "type": ["number", "null"] },
        "no_improvement_rounds": { "type": ["integer", "null"], "minimum": 1 },
        "min_delta":             { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "kind",
        "generated_at",
        "generated_by",
        "rationale"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["initial", "llm_proposed", "human_edited", "rule_based"],
          "description": "'initial' for round 1 (no bundle). Otherwise describe producer."
        },
        "source_round_id": {
          "type": ["string", "null"],
          "pattern": "^(round_[0-9]{2,}|)$",
          "description": "Round whose bundle drove this config. Null for 'initial'."
        },
        "source_bundle_hash": {
          "type": ["string", "null"],
          "pattern": "^([a-f0-9]{64}|)$",
          "description": "sha256 of canonicalised source bundle JSON. Null for 'initial'."
        },
        "parent_config_hash": {
          "type": ["string", "null"],
          "pattern": "^([a-f0-9]{64}|)$",
          "description": "sha256 of the previous round's config. Null for 'initial'."
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 UTC."
        },
        "generated_by": {
          "type": "object",
          "required": ["tool"],
          "additionalProperties": false,
          "properties": {
            "tool":           { "type": "string", "examples": ["claude_code", "codex_cli", "human", "rule_script"] },
            "model":          { "type": ["string", "null"] },
            "prompt_version": { "type": ["string", "null"] },
            "prompt_path":    { "type": ["string", "null"] }
          }
        },
        "reviewer": {
          "type": ["object", "null"],
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind":        { "type": "string", "enum": ["human", "auto"] },
            "id":          { "type": ["string", "null"] },
            "approved_at": { "type": ["string", "null"], "format": "date-time" },
            "comments":    { "type": ["string", "null"] }
          }
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "description": "Why each change was made. MUST cite bundle fields (param_importances, boundary_hits, axis_coverage, top_trials, …). For 'narrow' actions the evidence MUST include axis_coverage (or acknowledge 'coverage unknown' for legacy bundles); see docs/anti_patterns.md#a10."
        },
        "diff_summary": {
          "type": "array",
          "description": "Structured summary of changes vs parent config.",
          "items": {
            "type": "object",
            "required": ["action", "target"],
            "additionalProperties": false,
            "properties": {
              "action":  { "type": "string", "enum": ["narrow", "shift", "expand", "freeze", "unfreeze", "add", "remove", "replace_sampler", "replace_pruner", "split"] },
              "target":  { "type": "string", "description": "Param name or 'sampler' / 'pruner'." },
              "before":  {},
              "after":   {},
              "evidence":{ "type": "string", "description": "Bundle field reference, e.g. 'param_importances.lr=0.01'." }
            }
          }
        }
      }
    },
    "notes": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "provenance": { "properties": { "kind": { "const": "initial" } } } } },
      "then": {
        "properties": {
          "provenance": {
            "properties": {
              "source_round_id":    { "type": "null" },
              "source_bundle_hash": { "type": "null" },
              "parent_config_hash": { "type": "null" }
            }
          }
        }
      },
      "else": {
        "properties": {
          "provenance": {
            "required": ["source_round_id", "source_bundle_hash", "parent_config_hash"],
            "properties": {
              "source_round_id":    { "type": "string" },
              "source_bundle_hash": { "type": "string" },
              "parent_config_hash": { "type": "string" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "param": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "low", "high"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["float", "int"] },
            "low":  { "type": "number" },
            "high": { "type": "number" },
            "step": { "type": ["number", "null"] },
            "log":  { "type": "boolean", "default": false }
          }
        },
        {
          "type": "object",
          "required": ["type", "choices"],
          "additionalProperties": false,
          "properties": {
            "type":    { "type": "string", "const": "categorical" },
            "choices": {
              "type": "array",
              "minItems": 1,
              "items": { "type": ["string", "number", "boolean", "null"] }
            }
          }
        }
      ]
    }
  }
}
